# For ingest CLI (extraction + embedding)
OPENAI_API_KEY=sk-...

# For Worker (set via `wrangler secret put` for production)
# OPENAI_API_KEY and ANTHROPIC_API_KEY are set as Worker secrets
# For local wrangler dev, create apps/api/.dev.vars:
#   OPENAI_API_KEY=sk-...
#   ANTHROPIC_API_KEY=sk-ant-...
